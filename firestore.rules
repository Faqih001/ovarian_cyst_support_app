rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isValidUser() {
      return request.auth.uid != null 
        && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isAuthenticated() && 
        ('admin' in request.auth.token.roles || 
        exists(/databases/$(database)/documents/adminUsers/$(request.auth.uid)));
    }

    function hasRequiredFields(requiredFields) {
      return request.resource.data.keys().hasAll(requiredFields);
    }

    function isValidTimestamp() {
      return request.resource.data.createdAt == request.time;
    }

    function onlyFieldsChanged(allowedFields) {
      return request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(allowedFields);
    }

    // Admin users collection
    match /adminUsers/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // User profiles with admin access
    match /users/{userId} {
      allow read: if isAuthenticated() || isAdmin();
      allow create: if isOwner(userId) 
        && hasRequiredFields(['name', 'email', 'createdAt'])
        && isValidTimestamp();
      allow update: if isOwner(userId)
        && onlyFieldsChanged(['name', 'photoUrl', 'preferences', 'settings', 'updatedAt'])
        || isAdmin();
      allow delete: if isAdmin();
    }

    // User agreements
    match /user_agreements/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) 
        && hasRequiredFields(['agreedToTerms', 'agreedToPrivacyPolicy', 'timestamp'])
        && request.resource.data.timestamp == request.time;
      allow delete: if false;
    }

    // Medical records with enhanced privacy
    match /users/{userId}/medicalRecords/{document} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId)
        && hasRequiredFields(['type', 'date', 'details', 'createdAt'])
        && isValidTimestamp();
      allow update: if isOwner(userId)
        && onlyFieldsChanged(['details', 'updatedAt', 'attachments']);
      allow delete: if isOwner(userId);
    }

    // Symptoms tracking with timestamps
    match /users/{userId}/symptoms/{symptomId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId)
        && hasRequiredFields(['type', 'severity', 'timestamp', 'description'])
        && request.resource.data.timestamp == request.time;
      allow update: if isOwner(userId)
        && onlyFieldsChanged(['severity', 'description', 'updatedAt']);
      allow delete: if isOwner(userId);
    }

    // Appointments with reminders
    match /users/{userId}/appointments/{appointmentId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId)
        && hasRequiredFields(['date', 'time', 'doctor', 'location', 'type', 'createdAt'])
        && isValidTimestamp();
      allow update: if isOwner(userId)
        && onlyFieldsChanged(['date', 'time', 'doctor', 'location', 'notes', 'reminder', 'updatedAt']);
      allow delete: if isOwner(userId);
    }

    // Medications tracking
    match /users/{userId}/medications/{medicationId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId)
        && hasRequiredFields(['name', 'dosage', 'frequency', 'startDate', 'createdAt'])
        && isValidTimestamp();
      allow update: if isOwner(userId)
        && onlyFieldsChanged(['dosage', 'frequency', 'endDate', 'notes', 'reminder', 'updatedAt']);
      allow delete: if isOwner(userId);
    }

    // Community posts with moderation
    match /communityPosts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isValidUser()
        && hasRequiredFields(['content', 'createdAt', 'userId', 'title', 'category'])
        && request.resource.data.userId == request.auth.uid
        && isValidTimestamp()
        && request.resource.data.reportCount == 0
        && request.resource.data.isBlocked == false;
      allow update: if isValidUser()
        && (resource.data.userId == request.auth.uid
            && onlyFieldsChanged(['content', 'title', 'category', 'updatedAt'])
            || (isAuthenticated() && onlyFieldsChanged(['reportCount', 'reports'])));
      allow delete: if resource.data.userId == request.auth.uid;
    }

    // Comments with moderation
    match /communityPosts/{postId}/comments/{commentId} {
      allow read: if isAuthenticated();
      allow create: if isValidUser()
        && hasRequiredFields(['content', 'createdAt', 'userId'])
        && request.resource.data.userId == request.auth.uid
        && isValidTimestamp()
        && request.resource.data.reportCount == 0
        && request.resource.data.isBlocked == false;
      allow update: if isValidUser()
        && (resource.data.userId == request.auth.uid
            && onlyFieldsChanged(['content', 'updatedAt'])
            || (isAuthenticated() && onlyFieldsChanged(['reportCount', 'reports'])));
      allow delete: if resource.data.userId == request.auth.uid;
    }

    // Educational content - read-only for users
    match /educationalContent/{contentId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // Healthcare providers directory
    match /healthcareProviders/{providerId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // User notifications
    match /users/{userId}/notifications/{notificationId} {
      allow read: if isOwner(userId);
      allow create: if isValidUser()
        && hasRequiredFields(['type', 'message', 'createdAt', 'isRead'])
        && isValidTimestamp();
      allow update: if isOwner(userId)
        && onlyFieldsChanged(['isRead', 'readAt']);
      allow delete: if isOwner(userId);
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
